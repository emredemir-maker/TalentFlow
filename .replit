modules = ["nodejs-20", "web"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["firebase-tools"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3002

[[ports]]
localPort = 23636
externalPort = 3000

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "node server.js & npx vite preview --port 5000 --host 0.0.0.0"]
build = ["npm", "run", "build"]

[userenv]

[userenv.shared]
VITE_FIREBASE_AUTH_DOMAIN = "talentflow-84bb6.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID = "talentflow-84bb6"
VITE_FIREBASE_STORAGE_BUCKET = "talentflow-84bb6.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID = "132883257197"
VITE_FIREBASE_APP_ID = "1:132883257197:web:9c569a6c8fa52b0cfe6c64"
