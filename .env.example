# Firebase Configuration
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Gemini AI Configuration
# IMPORTANT: Anahtar SADECE sunucu tarafında okunur (server.js + functions/server.js).
# `VITE_` ön ekini KULLANMAYIN — aksi halde anahtar tarayıcı bundle'ına gömülür ve
# Google'ın güvenlik tarayıcıları tarafından otomatik iptal edilir.
GEMINI_API_KEY=your_gemini_api_key

# Email Configuration (Backend)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Server Configuration
SERVER_URL=http://localhost:3001
