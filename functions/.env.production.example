# Firebase Functions production environment variables
# Copy this file to functions/.env.production and fill in the values.
# DO NOT commit functions/.env.production to git (already in .gitignore).
#
# Firebase CLI uploads .env.production automatically when you run:
#   firebase deploy --only functions

EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-gmail-app-password
VITE_GEMINI_API_KEY=your-gemini-api-key
VITE_FIREBASE_API_KEY=your-firebase-api-key
