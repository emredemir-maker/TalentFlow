rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── CV uploads ────────────────────────────────────────────────────────────
    // AddCandidateModal uploads to: cvs/{timestamp}_{random}.{ext}  (flat path)
    // Write: any authenticated user (recruiters upload CVs for candidates)
    // Read:  any authenticated user (dashboard CV viewing)
    match /cvs/{filename} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                      && request.resource.size < 20 * 1024 * 1024;
    }

    // Nested paths under /cvs/ (future-proofing for sub-folder uploads)
    match /cvs/{candidateId}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                      && request.resource.size < 20 * 1024 * 1024;
    }

    // Whitelist of safe raster image MIME types. Excludes image/svg+xml,
    // which can carry inline JS and is therefore an XSS vector when the
    // asset is later rendered as <img> on a same-origin domain.
    function isSafeImageType() {
      return request.resource.contentType in [
        'image/jpeg',
        'image/png',
        'image/webp',
        'image/gif'
      ];
    }

    // ── Branding assets ───────────────────────────────────────────────────────
    // BrandingSettingsPage uploads to: branding/logo_{timestamp}_{filename}
    // Write: super_admin only (Custom Claim role OR Firestore role).
    // Read:  any authenticated user.
    match /branding/{filename} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                      && request.auth.token.role == 'super_admin'
                      && request.resource.size < 10 * 1024 * 1024
                      && isSafeImageType();
    }

    // ── Profile / avatar images ───────────────────────────────────────────────
    // Write: only the owner of the avatar slot
    match /avatars/{userId}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
                      && request.auth.uid == userId
                      && request.resource.size < 5 * 1024 * 1024
                      && isSafeImageType();
    }

    // ── Default deny ──────────────────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
