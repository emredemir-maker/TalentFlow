rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── CV uploads ────────────────────────────────────────────────────────────
    // Candidates upload their own CVs to /cvs/{candidateId}/{filename}
    // Recruiters and super_admins can read all CVs
    // Owners can read/write their own CV slot
    match /cvs/{candidateId}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null &&
                      (request.auth.uid == candidateId ||
                       request.auth.token.email == 'emre.demir@infoset.app');
    }

    // ── Profile images ────────────────────────────────────────────────────────
    match /avatars/{userId}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Default deny ─────────────────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
