{
  "name": "talentflow",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"node functions/server.js\"",
    "build": "vite build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:ci": "eslint . --max-warnings=201",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:auth": "playwright test --config=playwright.config.auth.js",
    "build:e2e-auth": "vite build --mode e2e-auth",
    "check:deps": "node scripts/check-deps-sync.mjs",
    "check:bundle-size": "node scripts/check-bundle-size.mjs",
    "scrape": "node cli-scraper.mjs",
    "preview": "vite preview",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{ts,tsx}": [
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@tailwindcss/vite": "^4.1.18",
    "adm-zip": "^0.5.16",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "firebase": "^12.9.0",
    "firebase-admin": "^13.7.0",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "imap": "^0.8.19",
    "loglevel": "^1.9.2",
    "lucide-react": "^0.570.0",
    "mailparser": "^3.9.6",
    "mammoth": "^1.11.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.1",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^5.4.624",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "puppeteer": "^24.37.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.0",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.59.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.5"
  }
}
