rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/artifacts/talent-flow/public/data/users/$(request.auth.uid)).data;
    }

    
    function isSuperAdmin() {
      return isAuthenticated() && (getUserData().role == 'super_admin' || request.auth.token.email == 'emre.demir@infoset.app');
    }

    
    function isRecruiter() {
      return isAuthenticated() && (getUserData().role == 'recruiter' || isSuperAdmin());
    }

    // --- System Settings ---
    match /artifacts/talent-flow/public/data/settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // --- Users Collection ---
    match /artifacts/talent-flow/public/data/users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isSuperAdmin() || (request.auth.uid == userId);
      allow delete: if isSuperAdmin();
    }

    // --- Invitations ---
    match /artifacts/talent-flow/public/data/invitations/{inviteId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // --- Candidates ---
    match /artifacts/talent-flow/public/data/candidates/{candidateId} {
      allow read, write: if isRecruiter();
    }
    
    // --- Positions ---
    match /artifacts/talent-flow/public/data/positions/{posId} {
      allow read: if isAuthenticated();
      allow write: if isRecruiter();
    }

    // --- Departments ---
    match /artifacts/talent-flow/public/data/departments/{deptId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // --- Sources ---
    match /artifacts/talent-flow/public/data/sources/{sourceId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // --- Messages / Queue ---
    match /artifacts/talent-flow/public/data/messages/{msgId} {
      allow read, write: if isRecruiter();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
