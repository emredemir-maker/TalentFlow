rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Auth helpers ──────────────────────────────────────────────────────────
    // Strict: excludes anonymous sessions
    function isStrictAuthenticated() {
      return request.auth != null &&
        request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    // Loose: includes anonymous candidates on public routes
    function isAuthenticatedIncAnon() {
      return request.auth != null;
    }

    // Check if the caller's user document exists in Firestore
    function userDocExists() {
      return exists(/databases/$(database)/documents/artifacts/talent-flow/public/data/users/$(request.auth.uid));
    }

    // Read the caller's user profile (cached per request by Firestore)
    function getUserProfile() {
      return get(/databases/$(database)/documents/artifacts/talent-flow/public/data/users/$(request.auth.uid)).data;
    }

    // ── Role helpers ──────────────────────────────────────────────────────────
    function isSuperAdmin() {
      return isStrictAuthenticated() &&
        (request.auth.token.email == 'emre.demir@infoset.app' ||
         (userDocExists() && getUserProfile().role == 'super_admin'));
    }

    function isRecruiter() {
      return isStrictAuthenticated() &&
        (isSuperAdmin() ||
         (userDocExists() && getUserProfile().role == 'recruiter'));
    }

    function isDepartmentUser() {
      return isStrictAuthenticated() &&
        userDocExists() &&
        getUserProfile().role == 'department_user';
    }

    // Department-scoped candidate access check (document-level read)
    function canAccessCandidate(candidateData) {
      return isRecruiter() ||
        (isDepartmentUser() &&
         candidateData.department != null &&
         'departments' in getUserProfile() &&
         getUserProfile().departments != null &&
         candidateData.department in getUserProfile().departments);
    }

    // ── Invitations ───────────────────────────────────────────────────────────
    // Open read is required: pre-auth registration checks need to verify
    // invitation by email before the account even exists.
    // Write is super_admin only.
    match /artifacts/talent-flow/public/data/invitations/{inviteId} {
      allow read:  if true;
      allow write: if isSuperAdmin();
    }

    // ── Positions (public job board) ──────────────────────────────────────────
    // Anyone can read (job applicants). Recruiters can write.
    match /artifacts/talent-flow/public/data/positions/{positionId} {
      allow read:  if true;
      allow write: if isRecruiter();
    }

    // ── Applications (public submission) ─────────────────────────────────────
    // Anyone can submit. Only recruiters can read/manage.
    match /artifacts/talent-flow/public/data/applications/{applicationId} {
      allow create:              if true;
      allow read, update, delete: if isRecruiter();
    }

    // ── Candidates ────────────────────────────────────────────────────────────
    // • create: anonymous candidates submitting public forms
    // • get:    document-level read —
    //     - Anonymous users (live interview candidates): can read any candidate
    //       document by ID. The session ID (128-bit UUID capability token) is
    //       the access gate; without the link they can't know the candidate ID.
    //     - Authenticated recruiter: sees all candidates
    //     - Authenticated dept_user: only candidates in their departments array
    // • list:   query-level — recruiter or dept_user (client code sends a
    //           .where('department', 'in', [...]) filter for dept_users)
    // • update/delete: recruiter or super_admin only
    match /artifacts/talent-flow/public/data/candidates/{candidateId} {
      allow create:        if isAuthenticatedIncAnon();
      allow get:           if (isAuthenticatedIncAnon() &&
                                request.auth.token.firebase.sign_in_provider == 'anonymous') ||
                              canAccessCandidate(resource.data);
      allow list:          if isRecruiter() || isDepartmentUser();
      allow update, delete: if isRecruiter();
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    // • read:   self, or any recruiter/super_admin (needed for user-management UI)
    //           department_users can only read their own profile
    // • create: allow any authenticated user (registration flow)
    // • update: super_admin (any user), or self (own profile only)
    // • delete: super_admin only
    match /artifacts/talent-flow/public/data/users/{userId} {
      allow read:   if isSuperAdmin() ||
                       isRecruiter()  ||
                       (isStrictAuthenticated() && request.auth.uid == userId);
      allow create: if isAuthenticatedIncAnon();
      allow update: if isSuperAdmin() ||
                       (isStrictAuthenticated() && request.auth.uid == userId);
      allow delete: if isSuperAdmin();

      match /{allChildren=**} {
        allow read, write: if isStrictAuthenticated() &&
                              (request.auth.uid == userId || isSuperAdmin());
      }
    }

    // ── Departments ───────────────────────────────────────────────────────────
    // Read: any authenticated user (org chart visibility)
    // Write: super_admin only (structure changes are sensitive)
    match /artifacts/talent-flow/public/data/departments/{deptId} {
      allow read:  if isStrictAuthenticated();
      allow write: if isSuperAdmin();
    }

    // ── Sources (candidate origin tracking) ──────────────────────────────────
    // Anonymous users (candidates on the apply form) need to read sources for
    // the "where did you find us?" dropdown.
    match /artifacts/talent-flow/public/data/sources/{sourceId} {
      allow read:  if isAuthenticatedIncAnon();
      allow write: if isRecruiter();
    }

    // ── Settings ─────────────────────────────────────────────────────────────
    match /artifacts/talent-flow/public/data/settings/{settingId} {
      allow read:  if isRecruiter();
      allow write: if isSuperAdmin();
    }

    // ── Broad catch-all for any other talent-flow collections ─────────────────
    match /artifacts/talent-flow/public/data/{collectionName}/{docId} {
      allow read:  if isStrictAuthenticated();
      allow write: if isRecruiter();
    }

    // Recursive catch-all for deeper talent-flow paths
    match /artifacts/talent-flow/{allPaths=**} {
      allow read:  if isStrictAuthenticated();
      allow write: if isSuperAdmin();
    }

    // ── Live Interview Sessions ───────────────────────────────────────────────
    // • read:   open — sessionId (128-bit UUID) acts as capability token
    // • create: recruiter initialises session; candidate may also create on
    //           their first status write (setDoc merge:true on non-existing doc)
    // • update: any authenticated user (recruiter or anon candidate)
    // • delete: denied
    match /interviews/{sessionId} {
      allow read:          if true;
      allow create, update: if isAuthenticatedIncAnon();
      allow delete:         if false;
    }

    // ── Default deny ──────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
