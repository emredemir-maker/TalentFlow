rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    
    function isSuperAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == 'emre.demir@infoset.app' || 
         (exists(/databases/$(database)/documents/artifacts/talent-flow/public/data/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/artifacts/talent-flow/public/data/users/$(request.auth.uid)).data.role == 'super_admin'));
    }

    function isRecruiter() {
      return isAuthenticated() && 
        (isSuperAdmin() || 
         (exists(/databases/$(database)/documents/artifacts/talent-flow/public/data/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/artifacts/talent-flow/public/data/users/$(request.auth.uid)).data.role == 'recruiter'));
    }

    // --- Critical Path: Invitations ---
    // Anyone (even unauthenticated) MUST be able to check if an invitation exists
    // for their email during registration.
    match /artifacts/talent-flow/public/data/invitations/{inviteId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // --- Users & Settings ---
    match /artifacts/talent-flow/public/data/users/{userId} {
      allow read, create: if isAuthenticated();
      allow update: if isSuperAdmin() || (request.auth.uid == userId);
      allow delete: if isSuperAdmin();
      
      match /{allChildren=**} {
        allow read, write: if isAuthenticated() && (request.auth.uid == userId || isSuperAdmin());
      }
    }

    // --- Candidates, Positions, Departments, etc. ---
    // Broad rule for talent-flow data to ensure recruiters can work
    match /artifacts/talent-flow/public/data/{collectionName}/{docId} {
      allow read: if isAuthenticated();
      allow write: if isRecruiter();
    }

    // Recursive match for any other talent-flow paths
    match /artifacts/talent-flow/{allPaths=**} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // --- Live Interviews Collection ---
    // Allows candidates (anonymous) to update their status/lobby presence
    match /interviews/{sessionId} {
      allow read, write: if true;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
